{
  "name": "cogsync-cli",
  "version": "0.1.0-alpha.0",
  "description": "AI のリミット回復サイクルと人間の集中サイクルを同期させる CLI コーチ",
  "type": "module",
  "private": true,
  "bin": {
    "cogsync": "./bin/cogsync.js"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "status": "tsx src/index.ts status",
    "watch": "tsx src/index.ts watch",
    "test": "node --test --import tsx/esm tests/*.test.ts",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "commander": "^12.0.0",
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
